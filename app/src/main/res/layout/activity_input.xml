<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white"
    tools:context=".InputActivity">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Financial Story Builder"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary_yellow"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Understand Your Financial Needs"
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center" />

    </LinearLayout>

    <!-- ScrollView for content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Age Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 Your Age"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter your current age (years)"
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/ageInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="e.g., 35"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textColor="#333333"
                    android:textColorHint="#CCCCCC"
                    android:background="@drawable/edit_text_background"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Annual Income Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 Annual Income"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter your gross annual income"
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/incomeInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="e.g., 50000"
                    android:inputType="number|numberDecimal"
                    android:padding="12dp"
                    android:textColor="#333333"
                    android:textColorHint="#CCCCCC"
                    android:background="@drawable/edit_text_background"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Dependents Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👨‍👩‍👧‍👦 Number of Dependents"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Include children and others who depend on your income"
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/dependentsInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="e.g., 2"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textColor="#333333"
                    android:textColorHint="#CCCCCC"
                    android:background="@drawable/edit_text_background"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Info Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFF9C4"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ️ What happens next?"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_yellow_dark"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="We'll analyze your financial situation and show you how much protection your family would need if something happens to you. This helps you understand the true value of life insurance."
                    android:textSize="13sp"
                    android:textColor="@color/sunlife_gold"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Generate Button -->
    <Button
        android:id="@+id/generateButton"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Generate My Financial Story"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="@drawable/button_background"
        android:layout_marginTop="16dp" />

</LinearLayout>
